m", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L897"}, {"caller_nid": "page_paymenttracking", "callee": "min", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L897"}, {"caller_nid": "page_paymenttracking", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L963"}, {"caller_nid": "page_paymenttracking", "callee": "formatCurrency", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L1028"}, {"caller_nid": "page_paymenttracking", "callee": "(() => {\n                                                // Group entries by month\n                                                const monthOrder = [\"April\", \"May\", \"June\", \"July\", \"August\", \"September\", \"October\", \"November\", \"December\", \"January\", \"February\", \"March\"];\n                                                const grouped = {};\n                                                pendingLedgerEntries.forEach(entry => {\n                                                    const month = entry.month || 'Other';\n                                                    if (!grouped[month]) grouped[month] = [];\n                                                    grouped[month].push(entry);\n                                                });\n                                                const sortedMonths = Object.keys(grouped).sort(\n                                                    (a, b) => monthOrder.indexOf(a) - monthOrder.indexOf(b)\n                                                );\n\n                                                return sortedMonths.map((month, mIdx) => {\n                                                    const entries = grouped[month];\n                                                    const monthTotal = entries.reduce((sum, e) => sum + (e.amount - (e.paidAmount || 0)), 0);\n                                                    const hasOverdue = entries.some(e => e.status === 'OVERDUE');\n\n                                                    return (\n                                                        <div key={month}>\n                                                            {/* Month Header */}\n                                                            <div className={`flex items-center justify-between px-3 py-1.5 bg-muted/60 ${mIdx > 0 ? 'border-t' : ''}`}>\n                                                                <div className=\"flex items-center gap-2\">\n                                                                    <Calendar className=\"w-3 h-3 text-muted-foreground\" />\n                                                                    <span className=\"text-xs font-semibold\">{month}</span>\n                                                                    {hasOverdue && (\n                                                                        <span className=\"text-[9px] font-medium text-red-600 bg-red-100 px-1.5 py-0.5 rounded-full\">OVERDUE</span>\n                                                                    )}\n                                                                </div>\n                                                                <span className={`text-xs font-semibold ${hasOverdue ? 'text-red-600' : 'text-muted-foreground'}`}>\n                                                                    {formatCurrency(monthTotal)}\n                                                                </span>\n                                                            </div>\n                                                            {/* Month Entries */}\n                                                            {entries.map((entry) => {\n                                                                const balance = entry.amount - (entry.paidAmount || 0);\n                                                                const isOverdue = entry.status === 'OVERDUE';\n                                                                const paidPercent = entry.amount > 0 ? Math.round(((entry.paidAmount || 0) / entry.amount) * 100) : 0;\n\n                                                                return (\n                                                                    <label\n                                                                        key={entry.id}\n                                                                        className=\"flex items-center gap-3 px-3 py-2 hover:bg-muted/30 cursor-pointer border-t text-sm transition-colors\"\n                                                                    >\n                                                                        <Checkbox\n                                                                            checked={selectedInstallmentIds.includes(entry.id)}\n                                                                            onCheckedChange={() => toggleInstallment(entry.id)}\n                                                                        />\n                                                                        <div className=\"flex-1 min-w-0\">\n                                                                            <div className=\"flex items-center gap-1.5\">\n                                                                                <span className=\"font-medium text-xs truncate\">{entry.feeComponent?.name || 'Fee'}</span>\n                                                                            </div>\n                                                                            <div className=\"flex items-center gap-2 mt-0.5\">\n                                                                                <span className=\"text-[10px] text-muted-foreground\">\n                                                                                    Due: {new Date(entry.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}\n                                                                                </span>\n                                                                                {paidPercent > 0 && paidPercent < 100 && (\n                                                                                    <span className=\"text-[10px] text-amber-600 font-medium\">{paidPercent}% paid</span>\n                                                                                )}\n                                                                            </div>\n                                                                        </div>\n                                                                        <span className={`font-semibold text-xs tabular-nums ${isOverdue ? 'text-red-600' : ''}`}>\n                                                                            {formatCurrency(balance)}\n                                                                        </span>\n                                                                    </label>\n                                                                );\n                                                            })}\n                                                        </div>\n                                                    );\n                                                });\n                                            })", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L1079"}, {"caller_nid": "page_paymenttracking", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L1174"}, {"caller_nid": "page_paymenttracking", "callee": "formatCurrency", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\payments\\page.jsx", "source_location": "L1270"}]}