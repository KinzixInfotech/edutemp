                               <div className=\"flex flex-col items-center justify-center h-full text-gray-500 dark:text-zinc-500\">\n                                                <Activity className=\"w-12 h-12 mb-4\" />\n                                                <p>No events match your filters</p>\n                                                <p className=\"text-xs mt-1\">Try adjusting the filters above</p>\n                                            </div>\n                                        );\n                                    }\n\n                                    return (\n                                        <div className=\"divide-y divide-gray-100 dark:divide-zinc-800\">\n                                            {filteredEvents.map((event, idx) => (\n                                                <div key={event.id} className=\"px-4 py-2 hover:bg-gray-50 dark:hover:bg-zinc-800/50 transition-colors\">\n                                                    <div className=\"flex items-start gap-3\">\n                                                        <span className=\"text-gray-500 dark:text-zinc-500 text-xs w-20 shrink-0\">\n                                                            {new Date(event.eventTime).toLocaleTimeString()}\n                                                        </span>\n                                                        <span className={`px-2 py-0.5 rounded text-xs font-medium shrink-0 ${event.eventType === 'CHECK_IN'\n                                                            ? 'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-400'\n                                                            : 'bg-orange-100 text-orange-700 dark:bg-orange-900/50 dark:text-orange-400'\n                                                            }`}>\n                                                            {event.eventType === 'CHECK_IN' ? 'IN' : 'OUT'}\n                                                        </span>\n                                                        <div className=\"flex-1 min-w-0\">\n                                                            {event.isResolved ? (\n                                                                <span className=\"text-green-700 dark:text-green-400\">\n                                                                    {event.resolvedUser?.name || 'Unknown User'}\n                                                                </span>\n                                                            ) : (\n                                                                <span className=\"text-yellow-600 dark:text-yellow-400 flex items-center gap-1.5\">\n                                                                    <AlertCircle className=\"w-3.5 h-3.5\" />\n                                                                    Unresolved (ID: {event.deviceUserId})\n                                                                </span>\n                                                            )}\n                                                        </div>\n                                                        <span className=\"text-gray-500 dark:text-zinc-500 text-xs shrink-0\">\n                                                            {event.deviceName}\n                                                        </span>\n                                                    </div>\n                                                    {event.error && (\n                                                        <div className=\"mt-1 ml-20 text-red-600 dark:text-red-400 text-xs\">\n                                                            \u26a0 {event.error}\n                                                        </div>\n                                                    )}\n                                                </div>\n                                            ))}\n                                        </div>\n                                    );\n                                })", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\attendance\\user-mapping\\page.jsx", "source_location": "L934"}, {"caller_nid": "page_usermapping", "callee": "(() => {\n                                    const total = eventsData?.events?.length || 0;\n                                    const filtered = eventsData?.events?.filter((e) => {\n                                        if (eventTypeFilter !== 'all' && e.eventType !== eventTypeFilter) return false;\n                                        if (resolutionFilter === 'resolved' && !e.isResolved) return false;\n                                        if (resolutionFilter === 'unresolved' && e.isResolved) return false;\n                                        return true;\n                                    }).length || 0;\n                                    return eventTypeFilter !== 'all' || resolutionFilter !== 'all'\n                                        ? `${filtered} of ${total} events (filtered)`\n                                        : `${total} events`;\n                                })", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\attendance\\user-mapping\\page.jsx", "source_location": "L995"}, {"caller_nid": "page_usermapping", "callee": "floor", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\attendance\\user-mapping\\page.jsx", "source_location": "L1117"}, {"caller_nid": "page_usermapping", "callee": "some", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\attendance\\user-mapping\\page.jsx", "source_location": "L1156"}, {"caller_nid": "page_usermapping", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\attendance\\user-mapping\\page.jsx", "source_location": "L1