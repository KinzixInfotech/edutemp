                                            <p className=\"font-medium text-muted-foreground\">No optional services activated</p>\n                                                <p className=\"text-xs text-muted-foreground/70 mt-1 mb-4\">Activate transport, activity or hostel \u2014 charges appear in the ledger automatically</p>\n                                                <Button variant=\"outline\" size=\"sm\" onClick={() => setAddServiceOpen(true)}><Plus className=\"w-4 h-4 mr-1.5\" />Activate Optional Fee</Button>\n                                            </div>\n                                        ) : (\n                                            <div className=\"space-y-3\">\n                                                {activatedList.map(comp => (\n                                                    <div key={comp.id} className=\"border rounded-xl overflow-hidden bg-white dark:bg-slate-950\">\n                                                        <div className=\"flex items-center gap-4 p-4\">\n                                                            <div className=\"w-11 h-11 rounded-xl flex items-center justify-center shrink-0 border bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800 text-blue-600\">\n                                                                <Bus className=\"w-5 h-5\" />\n                                                            </div>\n                                                            <div className=\"flex-1 min-w-0\">\n                                                                <p className=\"font-semibold\">{comp.name}</p>\n                                                                <p className=\"text-xs text-muted-foreground mt-0.5\">{comp.entries} ledger entries \u00b7 Total: {INR(comp.totalAmount)}</p>\n                                                            </div>\n                                                            <div className=\"text-right shrink-0\">\n                                                                <p className=\"font-bold\">{INR(comp.amount)}<span className=\"text-xs font-normal text-muted-foreground\">/mo</span></p>\n                                                                <Badge className=\"text-[10px] bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400\">Active</Badge>\n                                                            </div>\n                                                        </div>\n                                                    </div>\n                                                ))}\n                                            </div>\n                                        );\n                                    })", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L591"}, {"caller_nid": "page_studentfeedetails", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L643"}, {"caller_nid": "page_studentfeedetails", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L657"}, {"caller_nid": "page_studentfeedetails", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L682"}, {"caller_nid": "page_studentfeedetails", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L698"}, {"caller_nid": "page_studentfeedetails", "callee": "map", "source_file": "C:\\Users\\theco\\Downloads\\edubreezy_web\\edutemp\\src\\app\\dashboard\\fees\\students\\[studentId]\\page.jsx", "source_location": "L714"}, {"caller_nid